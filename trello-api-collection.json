    {
      "name": "Create Board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Board created successfully\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let response = pm.response.json();\r",
              "\r",
              "// Save idBoard for future requests\r",
              "if (response.id) {\r",
              "    pm.collectionVariables.set(\"idBoard\", response.id);\r",
              "    console.log(\"Board ID saved:\", response.id);\r",
              "} else {\r",
              "    console.warn(\"No board ID found in response.\");\r",
              "}\r",
              "\r",
              "// --- Extra checks on important properties ---\r",
              "pm.test(\"Board has a name\", function () {\r",
              "    pm.expect(response.name).to.be.a(\"string\").that.is.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"Board has a valid URL\", function () {\r",
              "    pm.expect(response.url).to.be.a(\"string\").and.to.include(\"https://trello.com/b/\");\r",
              "});\r",
              "\r",
              "pm.test(\"Board is open (not closed)\", function () {\r",
              "    pm.expect(response.closed).to.be.false;\r",
              "});\r",
              "\r",
              "pm.test(\"Board has prefs object with default settings\", function () {\r",
              "    pm.expect(response).to.have.property(\"prefs\");\r",
              "    pm.expect(response.prefs.permissionLevel).to.equal(\"private\");\r",
              "    pm.expect(response.prefs.cardCovers).to.be.true;\r",
              "    pm.expect(response.prefs.selfJoin).to.be.true;\r",
              "});\r",
              "\r",
              "pm.test(\"Board has labelNames object\", function () {\r",
              "    pm.expect(response).to.have.property(\"labelNames\");\r",
              "    pm.expect(response.labelNames).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "pm.test(\"Board belongs to an organization\", function () {\r",
              "    pm.expect(response).to.have.property(\"idOrganization\");\r",
              "    pm.expect(response.idOrganization).to.be.a(\"string\").that.is.not.empty;\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Trello doesn't allow duplicate board names - this counter ensures each run creates a unique name\r",
              "let bnRaw = pm.collectionVariables.get(\"boardNumber\");\r",
              "\r",
              "let computedName;\r",
              "\r",
              "// First run: initialize the counter and use the base name with no suffix\r",
              "if (bnRaw === undefined || bnRaw === null || bnRaw === \"\") {\r",
              "  pm.collectionVariables.set(\"boardNumber\", 0);\r",
              "  computedName = \"Nathalia\";\r",
              "} else {\r",
              "  // Subsequent runs: increment the counter and append it to the name (Nathalia1, Nathalia2...)\r",
              "  let n = parseInt(bnRaw, 10);\r",
              "  n += 1;\r",
              "  pm.collectionVariables.set(\"boardNumber\", n);\r",
              "  computedName = `Nathalia${n}`;\r",
              "}\r",
              "\r",
              "// Store the name in a request-scoped variable so it's available in the request body\r",
              "pm.variables.set(\"boardName\", computedName);\r",
              "console.log(\"Creating board with name:\", computedName);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "https://api.trello.com/1/boards/?name={{boardName}}&key={{trellokey}}&token={{trellotoken}}",
          "protocol": "https",
          "host": [
            "api",
            "trello",
            "com"
          ],
          "path": [
            "1",
            "boards",
            ""
          ],
          "query": [
            {
              "key": "name",
              "value": "{{boardName}}"
            },
            {
              "key": "key",
              "value": "{{trellokey}}"
            },
            {
              "key": "token",
              "value": "{{trellotoken}}"
            }
          ]
        }
      },
      "response": []
    },
