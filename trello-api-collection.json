    {
      "name": "Create a Card",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const json = pm.response.json();\r",
              "\r",
              "// Save the Card ID\r",
              "if (json.id) {\r",
              "    pm.collectionVariables.set(\"CardId\", json.id);\r",
              "    console.log(\"Card ID saved:\", json.id);\r",
              "} else {\r",
              "    throw new Error(\"No card id found in response.\");\r",
              "}\r",
              "\r",
              "// 🔎 Assertions\r",
              "\r",
              "// 1. Check that the card name is \"Hi Nathalia\"\r",
              "pm.test('Card name is \"Hi Nathalia\"', () => {\r",
              "    pm.expect(json.name).to.equal(\"Hi Nathalia\");\r",
              "});\r",
              "\r",
              "// 2. Check that the card was created in the TODO list\r",
              "pm.test(\"Card belongs to the TODO list\", () => {\r",
              "    const todoListId = pm.collectionVariables.get(\"todoListId\");\r",
              "    pm.expect(json.idList).to.equal(todoListId);\r",
              "});\r",
              "\r",
              "// 3. Check that the card belongs to the board where the TODO list is located\r",
              "pm.test(\"Card belongs to the correct board\", () => {\r",
              "    const boardId = pm.collectionVariables.get(\"idBoard\");\r",
              "    pm.expect(json.idBoard).to.equal(boardId);\r",
              "});\r",
              "\r",
              "// 4. Check that the card has no attachments\r",
              "pm.test(\"Card has no attachments\", () => {\r",
              "    // Trello returns `badges.attachments` count\r",
              "    pm.expect(json).to.have.property(\"badges\");\r",
              "    pm.expect(json.badges).to.have.property(\"attachments\", 0);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
